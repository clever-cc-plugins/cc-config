#!/usr/bin/env bash
# Non-blocking reminder: checks if any staged .claude/skills/<name> folders
# are missing from scripts/sync-to-main.sh's PRODUCT_PATHS.

SYNC_SCRIPT="$(git rev-parse --show-toplevel)/scripts/sync-to-main.sh"

# Extract unique skill folder names from staged files
staged_skills=()
while IFS= read -r file; do
  if [[ "$file" =~ ^plugins/([^/]+)/ ]]; then
    skill="${BASH_REMATCH[1]}"
    if [[ ! " ${staged_skills[*]} " =~ " ${skill} " ]]; then
      staged_skills+=("$skill")
    fi
  fi
done < <(git diff --cached --name-only)

[[ ${#staged_skills[@]} -eq 0 ]] && exit 0

# Extract skill names listed in PRODUCT_PATHS from the sync script
product_skills=()
if [[ -f "$SYNC_SCRIPT" ]]; then
  while IFS= read -r line; do
    if [[ "$line" =~ plugins/([^\"[:space:]]+) ]]; then
      product_skills+=("${BASH_REMATCH[1]}")
    fi
  done < <(grep 'plugins/' "$SYNC_SCRIPT")
fi

# Report any staged skills not found in PRODUCT_PATHS
missing=()
for skill in "${staged_skills[@]}"; do
  if [[ ! " ${product_skills[*]} " =~ " ${skill} " ]]; then
    missing+=("$skill")
  fi
done

if [[ ${#missing[@]} -gt 0 ]]; then
  echo ""
  echo "sync-to-main reminder:"
  echo "  The following staged skill(s) are not in scripts/sync-to-main.sh PRODUCT_PATHS:"
  for s in "${missing[@]}"; do
    echo "    - .claude/skills/$s"
  done
  echo "  Add them to PRODUCT_PATHS if they are product skills."
  echo "  Ignore this message if they are dev-only skills."
  echo ""
fi

exit 0
